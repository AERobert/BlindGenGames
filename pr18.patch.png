From b3195300c565e01ae165cd943f0b235f0e328b8b Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Mon, 19 Jan 2026 22:45:44 +0000
Subject: [PATCH 3/3] Fix multiplayer issues: accessibility, rejoin, and setup
 reinforcement

- Add skip link and 'S' key to access game info panel during other player's turn
- Add role="region" and proper ARIA attributes to game status section
- Implement rejoin functionality for ongoing games with disconnected players
  - Server tracks open slots and allows rejoining playing games
  - UI shows "Rejoin as [player]" buttons for games in progress
- Fix setup reinforcement to allow placing 3 troops across multiple territories
  - Track troops placed per round with setupTroopsPlacedThisRound
  - Only advance to next player when 3 troops placed or player out of armies
  - Sync round counter in multiplayer broadcasts
---
 Risk/css/styles.css |  24 +++++
 Risk/index.html     | 207 ++++++++++++++++++++++++++++++++++++++------
 Risk/js/game.js     |   8 +-
 Risk/js/network.js  |  28 ++++++
 Risk/js/state.js    |   2 +
 Risk/server.js      | 119 ++++++++++++++++++++++++-
 6 files changed, 356 insertions(+), 32 deletions(-)

diff --git a/Risk/css/styles.css b/Risk/css/styles.css
index 80ab463..4d8e875 100644
--- a/Risk/css/styles.css
+++ b/Risk/css/styles.css
@@ -440,6 +440,30 @@ button:disabled { background: #666; cursor: not-allowed; }
   font-style: italic;
 }
 
+.game-status-badge {
+  display: inline-block;
+  background: #e67e22;
+  color: #fff;
+  padding: 2px 8px;
+  border-radius: 4px;
+  font-size: 0.75rem;
+  font-weight: normal;
+  margin-left: 8px;
+  vertical-align: middle;
+}
+
+.game-item-actions {
+  display: flex;
+  flex-direction: column;
+  gap: 5px;
+}
+
+.game-item-actions button {
+  padding: 6px 12px;
+  font-size: 0.85rem;
+  white-space: nowrap;
+}
+
 /* Lobby Screen */
 .lobby-info {
   background: var(--bg);
