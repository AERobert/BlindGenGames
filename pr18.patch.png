+    // Rejoin an ongoing game with a specific player slot
+    function rejoinGameSlot(gameId, playerIndex) {
+      const playerName = playerNameInput?.value.trim() || playerNameInput?.dataset.generatedName || gameModule.generateCountryName();
+
+      if (!network.isConnected()) {
+        network.connect(
+          () => {
+            network.rejoinGame(gameId, playerName, playerIndex);
+          },
+          (error) => {
+            speech.speak('Cannot connect to server.');
+          }
+        );
+      } else {
+        network.rejoinGame(gameId, playerName, playerIndex);
+      }
+    }
+
+    // Rejoin a multiplayer game with existing game state
+    function rejoinMultiplayerGame(game, playerIndex, gameState) {
+      if (!gameState) {
+        speech.speak('Cannot rejoin: no game state available.');
+        return;
+      }
+
+      // Hide setup screen, show game screen
+      document.getElementById('setup-screen').classList.add('hidden');
+      document.getElementById('lobby-screen').classList.add('hidden');
+      document.getElementById('game-screen').classList.remove('hidden');
+
+      // Restore the game state
+      restore(gameState);
+      G.multiplayerMode = true;
+
+      // Mark which player is local (me) vs remote
+      for (let i = 0; i < G.players.length; i++) {
+        if (G.players[i].isHuman) {
+          G.players[i].isRemote = (i !== playerIndex);
+          G.players[i].connected = true;
+        }
+      }
+
+      // Update our tracked human player
+      G.humanPlayerId = playerIndex;
+
+      // Apply local settings
+      const savedPrefs = loadPreferences();
+      if (savedPrefs) {
+        G.aiDelay = savedPrefs.aiDelay ?? G.aiDelay;
+        if (savedPrefs.voiceName) speech.setVoice(savedPrefs.voiceName);
+        if (savedPrefs.rate) speech.setRate(savedPrefs.rate);
+      }
+
+      // Update UI
+      ui.updateUI();
+      speech.speak(`Rejoined game. ${G.phase} phase. ${currentPlayer()?.name || 'Unknown'}'s turn.`);
+
+      // If it's my turn, let me play. If not, wait for actions.
+      if (currentPlayer()?.id === playerIndex && currentPlayer()?.isHuman && !currentPlayer()?.isRemote) {
+        speech.speak('It is your turn.');
+      }
+    }
+
