diff --git a/Risk/css/styles.css b/Risk/css/styles.css
index 3f12887..80ab463 100644
--- a/Risk/css/styles.css
+++ b/Risk/css/styles.css
@@ -390,6 +390,169 @@ button:disabled { background: #666; cursor: not-allowed; }
   height: calc(100vh - 100px);
 }
 
+/* ============== MULTIPLAYER LOBBY ============== */
+.games-list {
+  max-height: 250px;
+  overflow-y: auto;
+  margin: 10px 0;
+}
+
+.game-item {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  padding: 12px;
+  background: var(--bg);
+  border-radius: 4px;
+  margin-bottom: 8px;
+  border: 1px solid var(--border);
+}
+
+.game-item:hover {
+  border-color: var(--accent);
+}
+
+.game-item-info {
+  flex: 1;
+}
+
+.game-item-name {
+  font-weight: bold;
+  font-size: 1.1rem;
+  color: var(--accent);
+}
+
+.game-item-details {
+  font-size: 0.85rem;
+  color: #aaa;
+  margin-top: 3px;
+}
+
+.game-item button {
+  padding: 8px 16px;
+  font-size: 0.9rem;
+}
+
+.no-games {
+  text-align: center;
+  color: #888;
+  padding: 20px;
+  font-style: italic;
+}
+
+/* Lobby Screen */
+.lobby-info {
+  background: var(--bg);
+  padding: 20px;
+  border-radius: 8px;
+  margin: 20px 0;
+}
+
+.lobby-players {
+  display: flex;
+  flex-direction: column;
+  gap: 10px;
+}
+
+.lobby-player-slot {
+  display: flex;
+  align-items: center;
+  padding: 12px 15px;
+  background: var(--panel);
+  border-radius: 4px;
+  border: 1px solid var(--border);
+}
+
+.lobby-player-slot.filled {
+  border-color: var(--success);
+}
+
+.lobby-player-slot.empty {
+  border-style: dashed;
+  color: #888;
+}
+
+.lobby-player-slot.ai {
+  border-color: var(--warning);
+  background: rgba(255, 154, 60, 0.1);
+}
+
+.lobby-player-slot.you {
+  border-color: var(--accent);
+  background: rgba(233, 69, 96, 0.1);
+}
+
+.lobby-player-color {
+  width: 24px;
+  height: 24px;
+  border-radius: 50%;
+  margin-right: 12px;
+}
+
+.lobby-player-name {
+  flex: 1;
+  font-weight: bold;
+}
+
+.lobby-player-status {
+  font-size: 0.85rem;
+  color: #aaa;
+}
+
+.lobby-player-slot.you .lobby-player-status {
+  color: var(--accent);
+}
+
+/* Connection Status */
+.connection-status {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  padding: 10px 15px;
+  border-radius: 4px;
+  margin: 15px 0;
+  font-size: 0.9rem;
+}
+
+.connection-status.connected {
+  background: rgba(78, 204, 163, 0.2);
+  color: var(--success);
+}
+
+.connection-status.disconnected {
+  background: rgba(233, 69, 96, 0.2);
+  color: var(--accent);
+}
+
+.connection-status.connecting {
+  background: rgba(255, 154, 60, 0.2);
+  color: var(--warning);
+}
+
+.status-dot {
+  width: 10px;
+  height: 10px;
+  border-radius: 50%;
+  background: currentColor;
+}
+
+.status-dot.pulsing {
+  animation: pulse-status 1s infinite;
+}
+
+@keyframes pulse-status {
+  0%, 100% { opacity: 1; }
+  50% { opacity: 0.5; }
+}
+
+/* Multiplayer Actions Display */
+.remote-action {
+  background: var(--highlight);
+  border-left: 3px solid var(--warning);
+  padding: 4px 8px;
+  margin: 2px 0;
+}
+
 /* Utils */
 .hidden { display: none !important; }
 :focus-visible { outline: 3px solid var(--accent); outline-offset: 2px; }
