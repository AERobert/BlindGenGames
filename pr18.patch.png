+
+      <div id="lobby-settings" class="setup-section">
+        <h3>Your Settings (local only)</h3>
+        <div class="setup-section">
+          <label for="lobby-voice-select">Voice:</label>
+          <select id="lobby-voice-select"></select>
+          <label for="lobby-speech-rate">Speech Rate: <span id="lobby-rate-value">1.2</span></label>
+          <input type="range" id="lobby-speech-rate" min="0.5" max="4" step="0.1" value="1.2" oninput="document.getElementById('lobby-rate-value').textContent=this.value">
+        </div>
+        <div class="setup-section">
+          <label for="lobby-ai-delay">AI Delay: <span id="lobby-delay-value">2</span>s</label>
+          <input type="range" id="lobby-ai-delay" min="0" max="5" step="0.1" value="2" oninput="document.getElementById('lobby-delay-value').textContent=parseFloat(this.value).toFixed(1)">
+          <label class="checkbox-label"><input type="checkbox" id="lobby-sound-effects" checked> Sound Effects</label>
+        </div>
+      </div>
+
+      <div style="margin-top:20px; display:flex; gap:10px; flex-wrap:wrap">
+        <button id="lobby-start-btn" onclick="game.startMultiplayerGame()" disabled>Start Game (Host Only)</button>
+        <button class="btn-secondary" onclick="game.leaveLobby()">Leave Lobby</button>
+      </div>
+    </div>
+
     <!-- GAME SCREEN -->
     <div id="game-screen" class="hidden">
       <header class="game-header" role="banner">
@@ -249,6 +307,7 @@ <h3>Card Trading</h3>
   <script src="js/ai.js"></script>
   <script src="js/ui.js"></script>
   <script src="js/map.js"></script>
+  <script src="js/network.js"></script>
   <script src="js/game.js"></script>
   <script>
     const { TERRITORIES, NAV_KEYS, findTerritory } = window.RiskData;
@@ -412,8 +471,783 @@ <h3>Card Trading</h3>
     // Handle game mode changes
     document.getElementById('game-mode')?.addEventListener('change', () => {
       updateStrategyCountStatus();
+      updateHumanPlayersOptions();
+    });
+
+    // ====== MULTIPLAYER SETUP ======
+    const network = window.RiskNetwork;
+    let multiplayerMode = false;
+    let myAssignedPlayerIndex = null;
+    let pendingGameConfig = null;
+    let playerAssignments = {}; // Maps clientId -> playerIndex
+
+    function updateHumanPlayersOptions() {
+      const numPlayers = parseInt(document.getElementById('num-players').value);
+      const gameMode = document.getElementById('game-mode').value;
+      const humanSelect = document.getElementById('num-humans');
+      const multiplayerNote = document.getElementById('multiplayer-note');
+      const startBtn = document.getElementById('start-btn');
+      const createLobbyBtn = document.getElementById('create-lobby-btn');
+      const gameNameSection = document.getElementById('multiplayer-name-section');
+      const availableGames = document.getElementById('available-games');
+
+      // Disable human players selector in spectator mode
+      if (gameMode === 'spectator') {
+        humanSelect.value = '1';
+        humanSelect.disabled = true;
+        multiplayerNote.classList.add('hidden');
+        startBtn.classList.remove('hidden');
+        createLobbyBtn.classList.add('hidden');
+        gameNameSection.classList.add('hidden');
+        availableGames.classList.add('hidden');
+        multiplayerMode = false;
+        return;
+      }
+
+      humanSelect.disabled = false;
+
+      // Update options to match player count
+      humanSelect.innerHTML = '';
+      for (let i = 1; i <= numPlayers; i++) {
+        const option = document.createElement('option');
+        option.value = i;
+        option.textContent = i === 1 ? '1 (Solo + AI)' : `${i} (Multiplayer)`;
+        humanSelect.appendChild(option);
+      }
+
+      // Keep previous selection if valid
+      const currentHumans = parseInt(humanSelect.value) || 1;
+      if (currentHumans <= numPlayers) {
+        humanSelect.value = currentHumans;
+      }
+
+      updateMultiplayerUI();
+    }
+
+    function updateMultiplayerUI() {
+      const numHumans = parseInt(document.getElementById('num-humans').value);
+      const multiplayerNote = document.getElementById('multiplayer-note');
+      const startBtn = document.getElementById('start-btn');
+      const createLobbyBtn = document.getElementById('create-lobby-btn');
+      const gameNameSection = document.getElementById('multiplayer-name-section');
+      const availableGames = document.getElementById('available-games');
+
+      multiplayerMode = numHumans > 1;
+
+      if (multiplayerMode) {
+        multiplayerNote.classList.remove('hidden');
+        startBtn.classList.add('hidden');
+        createLobbyBtn.classList.remove('hidden');
+        gameNameSection.classList.remove('hidden');
+        availableGames.classList.remove('hidden');
+
+        // Set default game name
+        const gameName = document.getElementById('game-name');
+        if (!gameName.value) {
+          const numPlayers = parseInt(document.getElementById('num-players').value);
+          const aiPlayers = numPlayers - numHumans;
+          const timestamp = new Date().toLocaleTimeString();
+          gameName.value = `Risk ${numHumans}H ${aiPlayers}AI ${timestamp}`;
+        }
+
+        // Try to connect and get games list
+        connectToServer();
+      } else {
+        multiplayerNote.classList.add('hidden');
+        startBtn.classList.remove('hidden');
+        createLobbyBtn.classList.add('hidden');
+        gameNameSection.classList.add('hidden');
+        availableGames.classList.add('hidden');
+      }
+
+      updateStrategyCountStatus();
+    }
+
+    function getRequiredAICountMultiplayer() {
+      const numPlayers = parseInt(document.getElementById('num-players').value);
+      const numHumans = parseInt(document.getElementById('num-humans').value);
+      const gameMode = document.getElementById('game-mode').value;
+      if (gameMode === 'spectator') return numPlayers;
+      return numPlayers - numHumans;
+    }
+
+    // Override getRequiredAICount for multiplayer
+    const originalGetRequiredAICount = getRequiredAICount;
+    getRequiredAICount = function() {
+      if (multiplayerMode) {
+        return getRequiredAICountMultiplayer();
+      }
+      return originalGetRequiredAICount();
+    };
+
+    // Handle human players change
+    document.getElementById('num-humans')?.addEventListener('change', () => {
+      updateMultiplayerUI();
+    });
+
+    document.getElementById('num-players')?.addEventListener('change', () => {
+      updateHumanPlayersOptions();
+    });
+
+    // Connect to multiplayer server
+    function connectToServer() {
+      if (network.isConnected()) {
+        network.getGames();
+        return;
+      }
+
+      network.connect(
+        () => {
+          console.log('Connected to multiplayer server');
+          speech.speak('Connected to server.');
+        },
+        (error) => {
+          console.error('Failed to connect:', error);
+          // Don't announce error repeatedly
+        }
+      );
+    }
+
+    // Setup network callbacks
+    network.setCallback('onConnected', (clientId, games) => {
+      console.log('Connected with ID:', clientId);
+      updateGamesList(games);
+    });
+
+    network.setCallback('onGamesList', (games) => {
+      updateGamesList(games);
+    });
+
+    network.setCallback('onGameCreated', (game, playerIndex) => {
+      myAssignedPlayerIndex = playerIndex;
+      showLobbyScreen(game, true);
+    });
+
+    network.setCallback('onGameJoined', (game, playerIndex) => {
+      myAssignedPlayerIndex = playerIndex;
+      showLobbyScreen(game, false);
+    });
+
+    network.setCallback('onPlayerJoined', (playerName, clientId, game) => {
+      speech.speak(`${playerName} joined the game.`);
+      log(`${playerName} joined the game`);
+      updateLobbyPlayers(game);
+    });
+
+    network.setCallback('onPlayerLeft', (playerName, clientId, game) => {
+      speech.speak(`${playerName} left the game.`);
+      log(`${playerName} left the game`);
+      if (game) {
+        updateLobbyPlayers(game);
+      }
+    });
+
+    network.setCallback('onGameStarted', (game, initialState, assignments) => {
+      playerAssignments = assignments;
+      startMultiplayerGameFromServer(game, initialState, assignments);
+    });
+
+    network.setCallback('onGameAction', (action, data, fromClientId, fromPlayerName) => {
+      handleRemoteAction(action, data, fromClientId, fromPlayerName);
+    });
+
+    network.setCallback('onSyncState', (state, fromClientId) => {
+      handleRemoteStateSync(state, fromClientId);
     });
 
+    network.setCallback('onError', (message) => {
+      speech.speak(`Error: ${message}`);
+    });
+
+    network.setCallback('onDisconnected', () => {
+      speech.speak('Disconnected from server.');
+    });
+
+    // Update games list UI
+    function updateGamesList(games) {
+      const container = document.getElementById('games-list');
+      if (!container) return;
+
+      if (!games || games.length === 0) {
+        container.innerHTML = '<p class="no-games">No games available. Create one or wait for others.</p>';
+        return;
+      }
+
+      container.innerHTML = '';
+      for (const game of games) {
+        const div = document.createElement('div');
+        div.className = 'game-item';
+        div.innerHTML = `
+          <div class="game-item-info">
+            <div class="game-item-name">${game.name}</div>
+            <div class="game-item-details">
+              ${game.currentPlayers}/${game.humanPlayers} humans, ${game.aiPlayers} AI
+            </div>
+          </div>
+          <button onclick="game.joinGameLobby('${game.id}')">Join</button>
+        `;
+        container.appendChild(div);
+      }
+    }
+
+    // Show lobby screen
+    function showLobbyScreen(game, isHost) {
+      document.getElementById('setup-screen').classList.add('hidden');
+      document.getElementById('lobby-screen').classList.remove('hidden');
+
+      document.getElementById('lobby-game-name').textContent = game.name;
+
+      const startBtn = document.getElementById('lobby-start-btn');
+      if (isHost) {
+        startBtn.disabled = !game.currentPlayers || game.currentPlayers < game.humanPlayers;
+        startBtn.textContent = game.currentPlayers >= game.humanPlayers
+          ? 'Start Game'
+          : `Waiting for ${game.humanPlayers - game.currentPlayers} more players...`;
+      } else {
+        startBtn.disabled = true;
+        startBtn.textContent = 'Waiting for host to start...';
+      }
+
+      updateLobbyPlayers(game);
+
+      // Apply voice settings to lobby
+      speech.populateVoiceSelect('lobby-voice-select');
+      const savedPrefs = loadPreferences();
+      if (savedPrefs?.voiceName) {
+        setTimeout(() => speech.setVoice(savedPrefs.voiceName), 300);
+      }
+    }
+
+    // Update lobby players display
+    function updateLobbyPlayers(game) {
+      const container = document.getElementById('lobby-players');
+      if (!container) return;
+
+      const { PLAYER_COLORS } = window.RiskData;
+      container.innerHTML = '';
+
+      // Create all player slots
+      for (let i = 0; i < game.totalPlayers; i++) {
+        const div = document.createElement('div');
+
+        // Find if this slot is filled by a human
+        const humanPlayer = game.players.find(p => p.playerIndex === i);
+        const isAI = i >= game.humanPlayers;
+        const isMe = humanPlayer && myAssignedPlayerIndex === i;
+
+        div.className = 'lobby-player-slot';
+        if (humanPlayer) div.classList.add('filled');
+        else if (isAI) div.classList.add('ai');
+        else div.classList.add('empty');
+        if (isMe) div.classList.add('you');
+
+        const color = PLAYER_COLORS[i];
+        div.innerHTML = `
+          <div class="lobby-player-color" style="background:${color.hex}"></div>
+          <div class="lobby-player-name">
+            ${humanPlayer ? humanPlayer.name : (isAI ? 'AI Player' : 'Waiting...')}
+          </div>
+          <div class="lobby-player-status">
+            ${color.name} - ${isMe ? '(You)' : (humanPlayer ? 'Ready' : (isAI ? 'Computer' : 'Empty'))}
+          </div>
+        `;
+        container.appendChild(div);
+      }
+
+      // Update start button
+      const startBtn = document.getElementById('lobby-start-btn');
+      const isHost = network.getIsHost();
+      if (isHost) {
+        const ready = game.currentPlayers >= game.humanPlayers;
+        startBtn.disabled = !ready;
+        startBtn.textContent = ready ? 'Start Game' : `Waiting (${game.currentPlayers}/${game.humanPlayers})...`;
+      }
+
+      document.getElementById('lobby-status').textContent =
+        `${game.currentPlayers}/${game.humanPlayers} human players joined`;
+    }
+
+    // Create a new game lobby
+    function createLobby() {
+      ensureSpeechReady();
+
+      if (!isStrategySelectionValid()) {
+        const requiredAI = getRequiredAICount();
+        speech.speak(`Please assign exactly ${requiredAI} AI strategies before creating the lobby.`);
+        return;
+      }
+
+      const playerName = playerNameInput?.value.trim() || playerNameInput?.dataset.generatedName || gameModule.generateCountryName();
+      const gameName = document.getElementById('game-name')?.value.trim() ||
+        `Risk Game ${new Date().toLocaleTimeString()}`;
+      const numPlayers = parseInt(document.getElementById('num-players').value);
+      const numHumans = parseInt(document.getElementById('num-humans').value);
+      const aiStrategies = getStrategySelections();
+
+      // Store game config for later
+      pendingGameConfig = {
+        playerName,
+        numPlayers,
+        numHumans,
+        gameMode: document.getElementById('game-mode').value,
+        aiStrategies
+      };
+
+      if (!network.isConnected()) {
+        network.connect(
+          () => {
+            network.createGame(playerName, gameName, numPlayers, numHumans, aiStrategies);
+          },
+          (error) => {
+            speech.speak('Cannot connect to server. Make sure the server is running with npm start.');
+          }
+        );
+      } else {
+        network.createGame(playerName, gameName, numPlayers, numHumans, aiStrategies);
+      }
+    }
+
+    // Join an existing game lobby
+    function joinGameLobby(gameId) {
+      const playerName = playerNameInput?.value.trim() || playerNameInput?.dataset.generatedName || gameModule.generateCountryName();
+
+      if (!network.isConnected()) {
+        network.connect(
+          () => {
+            network.joinGame(gameId, playerName);
+          },
+          (error) => {
+            speech.speak('Cannot connect to server.');
+          }
+        );
+      } else {
+        network.joinGame(gameId, playerName);
+      }
+    }
+
+    // Leave the lobby
+    function leaveLobby() {
+      network.leaveGame();
+      document.getElementById('lobby-screen').classList.add('hidden');
+      document.getElementById('setup-screen').classList.remove('hidden');
+      speech.speak('Left the lobby.');
+    }
+
+    // Refresh games list
+    function refreshGames() {
+      if (network.isConnected()) {
+        network.getGames();
+        speech.speak('Refreshing games list.');
+      } else {
+        connectToServer();
+      }
+    }
+
+    // Start multiplayer game (host only)
+    function startMultiplayerGame() {
+      if (!network.getIsHost()) {
+        speech.speak('Only the host can start the game.');
+        return;
+      }
+
+      const lobbySettings = {
+        voiceName: speech.getVoiceName(),
+        speechRate: parseFloat(document.getElementById('lobby-speech-rate')?.value || 1.2),
+        aiDelay: parseFloat(document.getElementById('lobby-ai-delay')?.value || 2) * 1000,
+        soundEnabled: document.getElementById('lobby-sound-effects')?.checked ?? true
+      };
+
+      // Initialize the game state
+      sounds.init();
+      sounds.setEnabled(lobbySettings.soundEnabled);
+      speech.setRate(lobbySettings.speechRate);
+      G.aiDelay = lobbySettings.aiDelay;
+
+      reset();
+      G.gameMode = pendingGameConfig.gameMode;
+      G.startTime = Date.now();
+      G.multiplayerMode = true;
+
+      // Initialize players with multiplayer setup
+      initPlayersMultiplayer(pendingGameConfig.numPlayers, pendingGameConfig.numHumans, pendingGameConfig.aiStrategies);
+      initTerritories();
+      initDeck();
+      initStats();
+
+      // Assign territories based on game mode
+      if (pendingGameConfig.gameMode === 'random' || pendingGameConfig.gameMode === 'random-troops' || pendingGameConfig.gameMode === 'empire') {
+        gameModule.randomAssignTerritories(pendingGameConfig.gameMode === 'empire');
+        if (pendingGameConfig.gameMode === 'random-troops') {
+          gameModule.randomPlaceTroops();
+        }
+      }
+
+      // Build player assignments mapping
+      const assignments = {};
+      // Get all connected players from the game info (we need to get this from network state)
+      // For now, we'll assign based on join order
+
+      // Send game start to server
+      const initialState = serialize();
+      network.startGame(initialState, assignments);
+    }
+
+    // Initialize players for multiplayer
+    function initPlayersMultiplayer(numPlayers, numHumans, aiStrategies) {
+      const { PLAYER_COLORS, STARTING_ARMIES } = window.RiskData;
+      const { STRATEGIES, STRATEGY_NAMES } = window.RiskAI;
+
+      G.players = [];
+      G.spectatorMode = false;
+      const usedNames = new Set();
+
+      // Get AI strategies
+      let aiStrategyList;
+      if (aiStrategies && aiStrategies.length > 0) {
+        aiStrategyList = [...aiStrategies];
+        // Shuffle AI strategies
+        for (let i = aiStrategyList.length - 1; i > 0; i--) {
+          const j = Math.floor(Math.random() * (i + 1));
+          [aiStrategyList[i], aiStrategyList[j]] = [aiStrategyList[j], aiStrategyList[i]];
+        }
+      } else {
+        const strategyPool = [...STRATEGY_NAMES];
+        for (let i = strategyPool.length - 1; i > 0; i--) {
+          const j = Math.floor(Math.random() * (i + 1));
+          [strategyPool[i], strategyPool[j]] = [strategyPool[j], strategyPool[i]];
+        }
+        aiStrategyList = [];
+        const aiCount = numPlayers - numHumans;
+        for (let i = 0; i < aiCount; i++) {
+          aiStrategyList.push(strategyPool[i % strategyPool.length]);
+        }
+      }
+
+      let aiIndex = 0;
+
+      // Create players in order - first humans, then AI
+      for (let i = 0; i < numPlayers; i++) {
+        const isHuman = i < numHumans;
+        let player;
+
+        if (isHuman) {
+          // Human player - name will be filled from network state
+          const name = i === myAssignedPlayerIndex
+            ? (playerNameInput?.value.trim() || 'Player ' + (i + 1))
+            : 'Player ' + (i + 1);
+          player = {
+            id: i,
+            name: name,
+            isHuman: true,
+            isRemote: i !== myAssignedPlayerIndex,
+            strategy: null,
+            strategyName: null,
+            cards: [],
+            eliminated: false
+          };
+        } else {
+          // AI player
+          const strategy = aiStrategyList[aiIndex++];
+          const countryName = gameModule.generateCountryName(usedNames);
+          usedNames.add(countryName);
+          player = {
+            id: i,
+            name: countryName,
+            isHuman: false,
+            isRemote: false,
+            strategy,
+            strategyName: STRATEGIES[strategy]?.name || strategy,
+            cards: [],
+            eliminated: false
+          };
+        }
+
+        player.color = PLAYER_COLORS[i].hex;
+        player.colorName = PLAYER_COLORS[i].name;
+        G.players.push(player);
+      }
+
+      G.humanPlayerId = myAssignedPlayerIndex;
+
+      const armies = STARTING_ARMIES[numPlayers] || 30;
+      for (const p of G.players) G.setupArmies[p.id] = armies;
+    }
+
+    // Called when server broadcasts game start
+    function startMultiplayerGameFromServer(game, initialState, assignments) {
+      document.getElementById('lobby-screen').classList.add('hidden');
+      document.getElementById('game-screen').classList.remove('hidden');
+
+      // Apply lobby settings
+      const lobbySettings = {
+        speechRate: parseFloat(document.getElementById('lobby-speech-rate')?.value || 1.2),
+        aiDelay: parseFloat(document.getElementById('lobby-ai-delay')?.value || 2) * 1000,
+        soundEnabled: document.getElementById('lobby-sound-effects')?.checked ?? true
+      };
+
+      sounds.init();
+      sounds.setEnabled(lobbySettings.soundEnabled);
+      speech.setRate(lobbySettings.speechRate);
+
+      // Restore state from server
+      restore(initialState);
+      G.aiDelay = lobbySettings.aiDelay;
+      G.multiplayerMode = true;
+
+      // Update player names from game info
+      for (const serverPlayer of game.players) {
+        const localPlayer = G.players[serverPlayer.playerIndex];
+        if (localPlayer) {
+          localPlayer.name = serverPlayer.name;
+          localPlayer.isRemote = serverPlayer.playerIndex !== myAssignedPlayerIndex;
+        }
+      }
+
+      G.humanPlayerId = myAssignedPlayerIndex;
+
+      // Initialize map
+      if (map) {
+        map.createMap();
+        const savedMapVisible = localStorage.getItem('riskMapVisible');
+        const mapContainer = document.getElementById('map-container');
+        const mapBtn = mapContainer?.querySelector('.map-toggle-btn:last-child');
+        if (savedMapVisible === 'false' && mapContainer) {
+          mapContainer.classList.add('hidden');
+          if (mapBtn) mapBtn.textContent = 'Show Map';
+        }
+      }
+
+      startIntervals();
+      ui.updateUI();
+
+      // Announce game start
+      const myPlayer = G.players[myAssignedPlayerIndex];
+      let startAnnouncement = 'Multiplayer game starting.';
+      startAnnouncement += ` You are ${myPlayer?.colorName || 'Unknown'}, player ${myAssignedPlayerIndex + 1} of ${G.players.length}.`;
+      speech.speak(startAnnouncement);
+      log('Multiplayer game started');
+
+      // Start the appropriate phase
+      const gameMode = G.gameMode;
+      if (gameMode === 'random' || gameMode === 'empire') {
+        gameModule.startSetupReinforce();
+      } else if (gameMode === 'random-troops') {
+        gameModule.startMainGame();
+      } else {
+        gameModule.startClaimPhase();
+      }
+    }
+
+    // Handle remote player actions
+    function handleRemoteAction(action, data, fromClientId, fromPlayerName) {
+      console.log('Remote action:', action, data, 'from', fromPlayerName);
+
+      switch (action) {
+        case 'claim':
+          applyRemoteClaim(data);
+          break;
+        case 'place':
+          applyRemotePlace(data);
+          break;
+        case 'attack':
+          applyRemoteAttack(data);
+          break;
+        case 'fortify':
+          applyRemoteFortify(data);
+          break;
+        case 'trade':
+          applyRemoteTrade(data);
+          break;
+        case 'endPhase':
+          applyRemoteEndPhase(data);
+          break;
+        case 'nextPlayer':
+          applyRemoteNextPlayer(data);
+          break;
+      }
+
+      ui.updateUI();
+    }
+
+    // Apply remote claim action
+    function applyRemoteClaim(data) {
+      const { territory, playerId, playerName } = data;
+      G.territories[territory].owner = playerId;
+      G.territories[territory].troops = 1;
+      G.setupArmies[playerId]--;
+      log(`${playerName} claims ${territory}`);
+      speech.speak(`${playerName} claims ${territory}.`);
+      sounds.play('place');
+
+      G.currentPlayer = (G.currentPlayer + 1) % G.players.length;
+      if (TERRITORIES.filter(t => G.territories[t.name].owner === null).length === 0) {
+        gameModule.startSetupReinforce();
+      } else {
+        ui.updateUI();
+        checkAndScheduleAI();
+      }
+    }
+
+    // Apply remote place action
+    function applyRemotePlace(data) {
+      const { territory, amount, playerId, playerName, phase, remaining } = data;
+      G.territories[territory].troops += amount;
+
+      if (phase === 'setup-reinforce') {
+        G.setupArmies[playerId] -= amount;
+        log(`${playerName} places ${amount} on ${territory} (${G.setupArmies[playerId]} left)`);
+        speech.speak(`${playerName} places ${amount} on ${territory}. ${G.setupArmies[playerId]} remaining.`);
+      } else {
+        G.armiesToPlace -= amount;
+        G.stats.troopsPlaced[playerId] += amount;
+        log(`${playerName} places ${amount} on ${territory}`);
+        speech.speak(`${playerName} places ${amount} on ${territory}. ${G.armiesToPlace} left.`);
+      }
+      sounds.play('place');
+    }
+
+    // Apply remote attack action
+    function applyRemoteAttack(data) {
+      const { from, to, result, playerName, conquered, defenderId } = data;
+
+      G.territories[from].troops = data.fromTroops;
+      G.territories[to].troops = data.toTroops;
+      G.territories[to].owner = data.toOwner;
+
+      log(`${playerName} attacks ${to} from ${from}`);
+      log(`  [${result.attackRolls}] vs [${result.defendRolls}]: -${result.attackerLosses}/-${result.defenderLosses}`);
+
+      speech.speak(`${playerName} attacks ${to} from ${from}.`);
+      sounds.play('attack');
+
+      if (conquered) {
+        log(`${playerName} conquers ${to}!`, true);
+        speech.speak(`${playerName} conquers ${to}!`);
+        sounds.play('victory');
+        G.conqueredThisTurn = true;
+        gameModule.checkContinentControl();
+
+        // Check if defender was eliminated
+        if (data.defenderEliminated) {
+          const defender = G.players[defenderId];
+          defender.eliminated = true;
+          G.stats.eliminated[defenderId] = G.turnNumber;
+          speech.speak(`${defender.name} eliminated!`);
+          sounds.play('elimination');
+          log(`${defender.name} eliminated`, true);
+
+          // Transfer cards
+          if (data.cardsTransferred) {
+            G.players[data.attackerId].cards.push(...defender.cards);
+            defender.cards = [];
+          }
+        }
+
+        // Check victory
+        const winner = gameModule.checkVictory();
+        if (winner !== null) {
+          gameModule.endGame(winner);
+        }
+      }
+    }
+
+    // Apply remote fortify action
+    function applyRemoteFortify(data) {
+      const { from, to, amount, playerName } = data;
+      G.territories[from].troops -= amount;
+      G.territories[to].troops += amount;
+      log(`${playerName} moves ${amount} from ${from} to ${to}`);
+      speech.speak(`${playerName} moves ${amount} from ${from} to ${to}.`);
+      sounds.play('fortify');
+    }
+
+    // Apply remote trade action
+    function applyRemoteTrade(data) {
+      const { playerId, playerName, value, territoryBonuses } = data;
+      G.armiesToPlace = (G.armiesToPlace || 0) + value;
+      G.tradeCount++;
+
+      // Apply territory bonuses
+      for (const territory of territoryBonuses) {
+        if (G.territories[territory]?.owner === playerId) {
+          G.territories[territory].troops += 2;
+        }
+      }
+
+      let ann = `${playerName} trades cards for ${value}`;
+      if (territoryBonuses.length > 0) {
+        ann += ` plus ${territoryBonuses.length * 2} on ${territoryBonuses.join(', ')}`;
+      }
+      speech.speak(ann + '.');
+      sounds.play('card');
+    }
+
+    // Apply remote end phase
+    function applyRemoteEndPhase(data) {
+      const { phase, nextPhase } = data;
+      G.phase = nextPhase;
+      if (nextPhase === 'attack') {
+        G.attackFrom = null;
+        speech.speak('Attack phase.');
+      } else if (nextPhase === 'fortify') {
+        G.attackFrom = null;
+        G.fortifyFrom = null;
+        speech.speak('Fortify phase.');
+      }
+    }
+
+    // Apply remote next player
+    function applyRemoteNextPlayer(data) {
+      G.currentPlayer = data.nextPlayer;
+      if (data.newTurn) {
+        G.turnNumber = data.turnNumber;
+      }
+      G.phase = 'reinforce';
+      G.armiesToPlace = data.armies;
+      G.conqueredThisTurn = false;
+      G.attackFrom = null;
+      G.fortifyFrom = null;
+      speech.speak(`${G.players[data.nextPlayer].name}'s turn.`);
+      checkAndScheduleAI();
+    }
+
+    // Handle full state sync from another player
+    function handleRemoteStateSync(state, fromClientId) {
+      restore(state);
+      G.humanPlayerId = myAssignedPlayerIndex;
+      G.multiplayerMode = true;
+      ui.updateUI();
+    }
+
+    // Helper to check if we should schedule AI
+    function checkAndScheduleAI() {
+      const player = currentPlayer();
