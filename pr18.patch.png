+        setTimeout(gameModule.aiTurn, G.aiDelay);
+      }
+    }
+
+    // Broadcast local action to other players
+    function broadcastAction(action, data) {
+      if (G.multiplayerMode && network.isConnected()) {
+        network.sendAction(action, data);
+      }
+    }
+
+    // Broadcast full state sync
